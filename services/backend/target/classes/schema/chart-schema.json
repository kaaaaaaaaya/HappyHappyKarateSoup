{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://happykaratesoup.dev/schema/chart-schema.json",
  "title": "Karate Soup Chart",
  "type": "object",
  "required": [
    "chartId",
    "soupName",
    "version",
    "schemaVersion",
    "bpm",
    "durationMs",
    "events"
  ],
  "properties": {
    "chartId": {
      "type": "string",
      "minLength": 1
    },
    "soupName": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "schemaVersion": {
      "type": "integer",
      "minimum": 1
    },
    "bpm": {
      "type": "integer",
      "minimum": 1
    },
    "durationMs": {
      "type": "integer",
      "minimum": 1
    },
    "events": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "timeMs",
          "action",
          "ingredientType",
          "lane",
          "windowMs"
        ],
        "properties": {
          "timeMs": {
            "type": "integer",
            "minimum": 0
          },
          "action": {
            "type": "string",
            "enum": [
              "tsuki",
              "shuto"
            ]
          },
          "ingredientType": {
            "type": "string",
            "minLength": 1
          },
          "lane": {
            "type": "string",
            "enum": [
              "left",
              "center",
              "right"
            ]
          },
          "windowMs": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
